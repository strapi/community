{
  "kind": "collectionType",
  "collectionName": "better_auth_invitations",
  "info": {
    "singularName": "invitation",
    "pluralName": "invitations",
    "displayName": "Invitations"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "content-manager": {
      "visible": false
    },
    "content-type-builder": {
      "visible": false
    }
  },
  "attributes": {
    "organizationId": {
      "type": "integer",
      "configurable": false,
      "pluginOptions": {
        "better-auth": {
          "managed": true
        }
      },
      "required": true
    },
    "email": {
      "type": "email",
      "configurable": false,
      "pluginOptions": {
        "better-auth": {
          "managed": true
        }
      },
      "required": true
    },
    "role": {
      "type": "string",
      "configurable": false,
      "pluginOptions": {
        "better-auth": {
          "managed": true
        }
      }
    },
    "status": {
      "type": "string",
      "configurable": false,
      "pluginOptions": {
        "better-auth": {
          "managed": true
        }
      },
      "required": true,
      "default": "pending"
    },
    "expiresAt": {
      "type": "datetime",
      "configurable": false,
      "pluginOptions": {
        "better-auth": {
          "managed": true
        }
      },
      "required": true
    },
    "inviterId": {
      "type": "integer",
      "configurable": false,
      "pluginOptions": {
        "better-auth": {
          "managed": true
        }
      },
      "required": true
    }
  }
}
