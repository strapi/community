{
  "kind": "collectionType",
  "collectionName": "security_reviews",
  "info": {
    "singularName": "security-review",
    "pluralName": "security-reviews",
    "displayName": "Security Review"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "status": {
      "type": "enumeration",
      "enum": ["pending", "running", "completed", "failed"],
      "default": "pending"
    },
    "started_at": { "type": "datetime" },
    "run_at": { "type": "datetime" },
    "dependencies": { "type": "json" },
    "ai_analysis": { "type": "json" },
    "summary": { "type": "json" },
    "package": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::package.package",
      "inversedBy": "security_reviews"
    }
  }
}
