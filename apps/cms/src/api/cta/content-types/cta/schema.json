{
  "kind": "collectionType",
  "collectionName": "ctas",
  "info": {
    "singularName": "cta",
    "pluralName": "ctas",
    "displayName": "Call To Action"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "content": {
      "type": "text",
      "required": true
    },
    "size": {
      "type": "enumeration",
      "required": true,
      "default": "L",
      "enum": [
        "L",
        "S"
      ]
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images"
      ]
    },
    "button": {
      "type": "component",
      "component": "shared.button",
      "repeatable": false,
      "required": true
    },
    "illustration": {
      "type": "enumeration",
      "required": true,
      "default": "image",
      "enum": [
        "image",
        "community_members"
      ]
    }
  }
}
