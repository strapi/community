{
  "kind": "collectionType",
  "collectionName": "showcases",
  "info": {
    "singularName": "showcase",
    "pluralName": "showcases",
    "displayName": "Showcases"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "webtools": {
      "enabled": false
    }
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "url": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text",
      "required": true
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "template": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::template.template"
    },
    "packages": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::package.package"
    },
    "categories": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::showcase-category.showcase-category"
    },
    "owner": {
      "type": "relation",
      "relation": "morphToMany"
    },
    "tech_stacks": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::tech-stack.tech-stack"
    }
  }
}
