{
  "kind": "collectionType",
  "collectionName": "recipes",
  "info": {
    "singularName": "recipe",
    "pluralName": "recipes",
    "displayName": "Recipes"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "webtools": {
      "enabled": true
    }
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text",
      "required": true
    },
    "content": {
      "type": "richtext",
      "required": true
    },
    "integrations": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::integration.integration"
    },
    "packages": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::package.package"
    }
  }
}
