{
  "kind": "collectionType",
  "collectionName": "profiles",
  "info": {
    "singularName": "profile",
    "pluralName": "profiles",
    "displayName": "Profiles"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "content-manager": {
      "visible": true
    },
    "content-type-builder": {
      "visible": true
    }
  },
  "attributes": {
    "bio": {
      "type": "text"
    },
    "subtitle": {
      "type": "string"
    },
    "website": {
      "type": "string"
    },
    "github": {
      "type": "string"
    },
    "location": {
      "type": "string"
    },
    "email": {
      "type": "string"
    },
    "readme": {
      "type": "richtext"
    },
    "avatar": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "owner": {
      "type": "relation",
      "relation": "morphToMany",
      "target": "plugin::better-auth.organization"
    },
    "countries": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::country.country"
    },
    "services": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::service.service"
    },
    "tech_stacks": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::tech-stack.tech-stack"
    }
  }
}
