{
  "kind": "collectionType",
  "collectionName": "profiles",
  "info": {
    "singularName": "profile",
    "pluralName": "profiles",
    "displayName": "Profiles"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "content-manager": {
      "visible": false
    },
    "content-type-builder": {
      "visible": true
    }
  },
  "attributes": {
    "bio": {
      "type": "text"
    },
    "website": {
      "type": "string"
    },
    "email": {
      "type": "string"
    },
    "avatar": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "owner": {
      "type": "relation",
      "relation": "morphToMany",
      "required": true,
      "mappedBy": "profile"
    }
  }
}
