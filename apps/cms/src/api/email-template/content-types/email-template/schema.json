    },
    "subject": {
      "type": "string",
      "required": true
    },
    "body": {
      "type": "richtext",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "from_name": {
      "type": "string"
    },
    "reply_to": {
      "type": "email"
    }
  }
}
