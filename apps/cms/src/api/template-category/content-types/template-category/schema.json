{
  "kind": "collectionType",
  "collectionName": "template_categories",
  "info": {
    "singularName": "template-category",
    "pluralName": "template-categories",
    "displayName": "Template categories"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "webtools": {
      "enabled": true
    }
  },
  "attributes": {
    "url_alias": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "plugin::webtools.url-alias",
      "configurable": false
    },
    "name": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text",
      "required": true
    },
    "children": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::template-category.template-category",
      "mappedBy": "parent"
    },
    "parent": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::template-category.template-category",
      "inversedBy": "children"
    },
    "sections": {
      "type": "dynamiczone",
      "components": ["sections.cta"]
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true,
      "regex": "^[A-Za-z0-9-_.~@]*$"
    }
  }
}
