{
  "$schema": "https://biomejs.dev/schemas/2.2.4/schema.json",
  "extends": "//",
  "linter": {
    "domains": {
      "next": "recommended"
    },
    "rules": {
      "style": {
        "noDefaultExport": "error"
      }
    }
  },
  "overrides": [
    {
      "includes": ["**/src/app/**", "./*"],
      "linter": {
        "rules": {
          "style": {
            "noDefaultExport": "off"
          }
        }
      }
    }
  ]
}
