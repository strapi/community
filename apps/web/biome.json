{
  "$schema": "https://biomejs.dev/schemas/2.4.11/schema.json",
  "root": true,
  "extends": ["@repo/biome-config"],
  "linter": {
    "domains": {
      "next": "recommended"
    },
    "rules": {
      "style": {
        "noDefaultExport": "error",
        "noNonNullAssertion": "off"
      },
      "suspicious": {
        "noNonNullAssertedOptionalChain": "off"
      }
    }
  },
  "overrides": [
    {
      "includes": ["**/src/app/**", "./*"],
      "linter": {
        "rules": {
          "style": {
            "noDefaultExport": "off"
          }
        }
      }
    }
  ]
}
